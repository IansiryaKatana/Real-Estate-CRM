# Supabase (Dashboard → Project Settings → API)
# Use the same project for URL and anon key. Reference ID is the subdomain: https://<REFERENCE_ID>.supabase.co
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_public_key_here
# Web Push (public VAPID key only; private key stays in integration secrets)
VITE_WEBPUSH_VAPID_PUBLIC_KEY=your_vapid_application_server_public_key_here
# Optional (Edge Functions can read these from project env vars instead of integration_secrets)
# RESEND_API_KEY=re_...
# RESEND_FROM_DOMAIN=yourdomain.com
# RESEND_REPLY_INBOX=inbox@yourdomain.com
# RESEND_INBOUND_TOKEN=strong_random_token
